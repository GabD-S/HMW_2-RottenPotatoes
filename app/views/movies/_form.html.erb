<%= form_with model: @movie do |f| %>
  <% if @movie.errors.any? %>
    <ul>
      <% @movie.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  <% end %>

  <p>
    <%= f.label :title, 'Título' %><br>
    <%= f.text_field :title %>
  </p>
  <p>
    <%= f.label :rating, 'Classificação' %><br>
    <%= f.text_field :rating %>
  </p>
  <p>
    <%= f.label :release_date, 'Data de Lançamento' %><br>
    <%= f.date_field :release_date %>
  </p>
  <p>
    <%= f.label :description, 'Descrição' %><br>
    <%= f.text_area :description %>
  </p>
  <p><%= f.submit %></p>
<% end %>
